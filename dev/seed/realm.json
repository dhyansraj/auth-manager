{
  "id": "dev",
  "realm": "dev",
  "displayName": "Local Dev Realm",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "platform-admin",
        "description": "Full admin over the auth-manager platform"
      }
    ]
  },
  "clients": [
    {
      "clientId": "auth-manager-ui",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "+"
      ]
    },
    {
      "clientId": "auth-manager-backend",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "secret": "dev-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": []
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@dev.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Local",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "platform-admin"
      ]
    }
  ]
}
