{
  "name": "@mcpmesh/auth-lib-react",
  "version": "0.3.0",
  "description": "React + BFF + PKCE hooks/components for the mcp-mesh auth platform",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhyansraj/auth-manager.git",
    "directory": "libs/auth-lib-react"
  },
  "homepage": "https://github.com/dhyansraj/auth-manager#readme",
  "bugs": {
    "url": "https://github.com/dhyansraj/auth-manager/issues"
  },
  "keywords": ["keycloak", "oauth2", "oidc", "pkce", "bff", "react", "mcp-mesh"],
  "author": "Dhyan Raj",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bff": {
      "types": "./dist/bff/index.d.ts",
      "import": "./dist/bff/index.js"
    },
    "./pkce": {
      "types": "./dist/pkce/index.d.ts",
      "import": "./dist/pkce/index.js"
    },
    "./vite-preset": {
      "types": "./dist/vite-preset/index.d.ts",
      "import": "./dist/vite-preset/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=18",
    "react-oidc-context": ">=3"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18",
    "jsdom": "^29.1.1",
    "react": "^18",
    "react-dom": "^18.3.1",
    "react-oidc-context": "^3",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
