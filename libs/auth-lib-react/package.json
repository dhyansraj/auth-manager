{
  "name": "@mcpmesh/auth-lib-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react --external react-oidc-context --external @tanstack/react-query",
    "dev": "tsup src/index.ts --format esm --dts --watch --external react --external react-oidc-context --external @tanstack/react-query"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-oidc-context": ">=3",
    "@tanstack/react-query": ">=5"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5",
    "react": "^18",
    "react-oidc-context": "^3",
    "@tanstack/react-query": "^5",
    "@types/react": "^18"
  }
}
